{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode",
    "@capybearista/opencode-adversarial-review@latest",
    "@capybearista/opencode-agents-loader@latest",
    "@capybearista/opencode-agent-prompt-inheritance@latest"
  ],
  "rules": ".opencode/RULES.md",
  "agents": {
    "rxpro-manager": {
      "description": "Project manager - tracks tasks, decisions, and state across sessions",
      "mode": "subagent",
      "instructions": "Read .opencode/agents/rxpro-manager.md and .opencode/memory/ for full context",
      "hide": false
    },
    "rxpro-builder": {
      "description": "Builds RxPro prescription management system",
      "mode": "full",
      "instructions": "Read .opencode/RULES.md then .opencode/agents/RxPro-context.md before making changes"
    }
  }
}
